VITE_API_URL=http://localhost:5005

# Google Places Autocomplete (get a key at console.cloud.google.com)
# Enable: Maps JavaScript API + Places API
# Restrict to your domain in production (HTTP referrer restriction)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox GL JS — get token at mapbox.com → Account → Access tokens
# Add this same token to your Render dashboard env vars
VITE_MAPBOX_TOKEN=pk.your_token_here
