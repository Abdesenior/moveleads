# ── API ───────────────────────────────────────────────────────────────────────
# Backend API base URL — must NOT have a trailing slash or /api suffix
VITE_API_URL=https://api.moveleads.cloud

# ── Google Maps ───────────────────────────────────────────────────────────────
# Create/find in Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API
# Restrict key to: https://moveleads.cloud/* and https://www.moveleads.cloud/*
VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
