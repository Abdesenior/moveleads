# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (LIVE cluster)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/moveleads?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use a DIFFERENT secret in production than in development.
JWT_SECRET=replace_with_a_64_byte_random_hex_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_ORIGIN=https://moveleads.cloud,https://www.moveleads.cloud

# ── Frontend URL ───────────────────────────────────────────────────────────────
# Used in Stripe Checkout success_url / cancel_url redirects (no trailing slash)
CLIENT_URL=https://moveleads.cloud

# ── Stripe (LIVE keys) ────────────────────────────────────────────────────────
# IMPORTANT: Use LIVE keys (sk_live_... / whsec_...) in production.
#            Never commit sk_test_... or sk_live_... keys to source control.
# Find in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Find in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (LIVE credentials) ─────────────────────────────────────────────────
# IMPORTANT: Use production Account SID + Auth Token (not test credentials).
#            Test credentials use magic numbers that never send real SMS.
# Find in: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your purchased Twilio phone number in E.164 format (e.g. +18005551234)
TWILIO_PHONE_NUMBER=+15005550006

# ── Resend (transactional email) ──────────────────────────────────────────────
# All emails (verification, dispute approvals) are sent via Resend.
# Domain moveleads.cloud must be verified in Resend Dashboard → Domains.
# Emails are sent from: no-reply@moveleads.cloud
# Find API key at: resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
